{
  "name": "soundshed",
  "version": "1.3.0",
  "description": "Browse and manage favourite tones, preview or store on your amp. Jam to Backing tracks and Lessons",
  "main": "./build/main.js",
  "repository": "https://github.com/soundshed/soundshed-app",
  "scripts": {
    "build-web": "npx tsc && webpack --config ./webpack.web.config.js",
    "build-electron": "npx tsc && webpack --config ./webpack.electron.config.js",
    "watch-web": "concurrently \"tsc -w\" \"webpack -w --config ./webpack.web.config.js\"",
    "watch-electron": "concurrently \"tsc -w\" \"webpack -w --config ./webpack.electron.config.js\"",
    "start-electron": "npx tsc && webpack --config ./webpack.electron.config.js && electron-forge start --inspect-electron",
    "test": "echo \"Error: no test specified\" && exit 1",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "author": "Webprofusion",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.7.0",
    "@electron-forge/maker-deb": "^7.7.0",
    "@electron-forge/maker-rpm": "^7.7.0",
    "@electron-forge/maker-squirrel": "^7.7.0",
    "@electron-forge/maker-zip": "^7.7.0",
    "@electron-forge/plugin-webpack": "^7.7.0",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "@types/web-bluetooth": "^0.0.21",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "@yaireo/tagify": "^4.32.0",
    "bootstrap": "^5.3.8",
    "concurrently": "^9.1.2",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "electron": "^41.0.0",
    "fork-ts-checker-webpack-plugin": "^9.0.0",
    "fs-extra": "^11.3.0",
    "html-webpack-plugin": "^5.6.3",
    "jwt-decode": "^3.1.2",
    "nanoid": "^4.0.2",
    "node-gyp": "^11.0.0",
    "node-loader": "^2.0.0",
    "node-polyfill-webpack-plugin": "^4.1.0",
    "path-browserify": "^1.0.1",
    "pullstate": "^1.25.0",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.4.5",
    "react-player": "^2.16.0",
    "react-router-dom": "^6.30.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.3",
    "webmidi": "3.1.2",
    "webpack": "^5.99.5",
    "webpack-cli": "^5.1.4",
    "youtube-search": "^1.1.6"
  },
  "dependencies": {
    "update-electron-app": "^2.0.1"
  },
  "config": {
    "forge": "./forge.config.js"
  },
  "overrides": {
    "axios": "^1.8.4",
    "xml2js": "^0.5.0"
  }
}
